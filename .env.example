# MobileChatServer Docker environment
# Copy this file to .env before running Docker Compose:
# cp .env.example .env

APP_ENV=development
PORT=8080
API_PORT=8080

POSTGRES_DB=mobilechat
POSTGRES_USER=mobilechat
POSTGRES_PASSWORD=change_this_database_password

# Keep host as postgres inside Docker Compose.
DATABASE_URL=postgres://mobilechat:change_this_database_password@postgres:5432/mobilechat?sslmode=disable

# Must be at least 32 characters.
JWT_SECRET=change_this_jwt_secret_to_a_long_random_value_32_chars_min
ACCESS_TOKEN_TTL_MINUTES=60

# For local/mobile testing you can keep *.
# For production set exact domains, for example:
# ALLOWED_ORIGINS=https://api.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

BCRYPT_COST=12

# Development only. Production must use a real SMS provider integration.
SMS_PROVIDER=dev
SMS_FROM=MobileChat

# Optional Firebase Cloud Messaging for push notifications.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Firebase Test Lab deterministic login. Keep disabled in normal production.
TEST_AUTH_ENABLED=false
TEST_AUTH_PHONE=+996700000001
TEST_AUTH_CODE=111111
TEST_AUTH_DISPLAY_NAME=Firebase Test User

# Content moderation.
# Rules filter is always included when CONTENT_MODERATION_ENABLED=true.
# Add OPENAI_API_KEY to also use OpenAI Moderation API.
CONTENT_MODERATION_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MODERATION_ENDPOINT=https://api.openai.com/v1/moderations
# false = if OpenAI is unavailable, keep local rules working and do not stop all posts.
# true = send content to manual review when OpenAI moderation cannot be reached.
MODERATION_FAIL_CLOSED=false
