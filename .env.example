# MobileChatServer local Docker environment
# Copy this file to .env before running Docker Compose:
# cp .env.example .env

APP_ENV=development
PORT=8080
API_PORT=8080

POSTGRES_DB=mobilechat
POSTGRES_USER=mobilechat
POSTGRES_PASSWORD=change_this_database_password

# Keep host as postgres inside Docker Compose.
DATABASE_URL=postgres://mobilechat:change_this_database_password@postgres:5432/mobilechat?sslmode=disable

# Must be at least 32 characters. Use a unique random value outside local development.
JWT_SECRET=change_this_jwt_secret_to_a_long_random_value_32_chars_min
ACCESS_TOKEN_TTL_MINUTES=60

# Local/mobile testing can use localhost origins.
# Production must use exact trusted domains only, for example:
# ALLOWED_ORIGINS=https://kginnovation.duckdns.org
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://kginnovation.duckdns.org

BCRYPT_COST=12

# Development only. Production must use a real SMS provider integration.
SMS_PROVIDER=dev
SMS_FROM=MobileChat

# Optional Firebase Cloud Messaging for push notifications.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Optional admin phone allowlists. Comma-separated E.164 phone numbers.
SUPER_ADMIN_PHONES=
PLATFORM_ADMIN_PHONES=
