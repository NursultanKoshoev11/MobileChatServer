# Copy this file to .env.prod and fill real values.
# Never commit .env.prod with real secrets.

APP_DOMAIN=api.example.com
APP_ENV=production
PORT=8080

POSTGRES_DB=mobilechat
POSTGRES_USER=mobilechat
POSTGRES_PASSWORD=replace_with_strong_database_password
DATABASE_URL=postgres://mobilechat:replace_with_strong_database_password@postgres:5432/mobilechat?sslmode=disable

JWT_SECRET=replace_with_at_least_32_random_characters_prefer_64_plus
ACCESS_TOKEN_TTL_MINUTES=5
ALLOWED_ORIGINS=https://example.com
BCRYPT_COST=12

# Production must use a real SMS provider. Twilio is implemented in cmd/server/sms_sender.go.
SMS_PROVIDER=twilio
SMS_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Platform roles. The project owner is always super_admin.
PROJECT_OWNER_PHONE=+996000000000
SUPER_ADMIN_PHONES=
PLATFORM_ADMIN_PHONES=

BACKUP_RETENTION_DAYS=14
RUN_MIGRATIONS_ON_START=false
REALTIME_BROKER=local
BACKEND_INSTANCE_COUNT=1

# Firebase Test Lab deterministic login. Keep disabled in normal production.
TEST_AUTH_ENABLED=false
TEST_AUTH_PHONE=+996700000001
TEST_AUTH_CODE=111111
TEST_AUTH_DISPLAY_NAME=Firebase Test User

# Content moderation / AI filters
CONTENT_MODERATION_ENABLED=true
CONTENT_MODERATION_PROVIDER=huggingface
HF_TOKEN=
HF_MODERATION_MODEL=unitary/multilingual-toxic-xlm-roberta
HF_MODERATION_ENDPOINT=https://api-inference.huggingface.co/models
HF_MODERATION_THRESHOLD=0.72
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MODERATION_ENDPOINT=https://api.openai.com/v1/moderations
MODERATION_FAIL_CLOSED=true
