# Copy this file to .env.prod and fill real values.
# Never commit .env.prod with real secrets.

APP_DOMAIN=api.example.com
APP_ENV=production
PORT=8080

POSTGRES_DB=mobilechat
POSTGRES_USER=mobilechat
POSTGRES_PASSWORD=replace_with_strong_database_password
DATABASE_URL=postgres://mobilechat:replace_with_strong_database_password@postgres:5432/mobilechat?sslmode=disable

JWT_SECRET=replace_with_at_least_32_random_characters_prefer_64_plus
ACCESS_TOKEN_TTL_MINUTES=60
ALLOWED_ORIGINS=https://example.com
BCRYPT_COST=12

# Production must not use dev.
# Add a real provider implementation before setting production live.
SMS_PROVIDER=disabled
SMS_FROM=MobileChat

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

BACKUP_RETENTION_DAYS=14
